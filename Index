            <button class="add-btn" onclick="addToCart('بذور خضار موسمية',3.00)">أضف للسلة</button></div>
        </div>
      </div>
    </div>

    <div class="prod-section" id="tools">
      <h3>أدوات ومعدات الحدائق</h3>
      <div class="prod-grid">
        <div class="prod-card">
          <div class="prod-thumb"></div>
          <h4>طقم أدوات تقليم يدوي</h4>
          <div class="prod-meta">طقم كامل</div>
          <div class="prod-row"><span class="price">12.00 ₪</span>
            <button class="add-btn" onclick="addToCart('طقم تقليم يدوي',12.00)">أضف للسلة</button></div>
        </div>
        <div class="prod-card">
          <div class="prod-thumb"></div>
          <h4>خرطوم ري 20 متر</h4>
          <div class="prod-meta">قطعة واحدة</div>
          <div class="prod-row"><span class="price">18.00 ₪</span>
            <button class="add-btn" onclick="addToCart('خرطوم ري 20م',18.00)">أضف للسلة</button></div>
        </div>
        <div class="prod-card">
          <div class="prod-thumb"></div>
          <h4>قفازات حديقة مقاومة للشوك</h4>
          <div class="prod-meta">زوج واحد</div>
          <div class="prod-row"><span class="price">5.00 ₪</span>
            <button class="add-btn" onclick="addToCart('قفازات حديقة',5.00)">أضف للسلة</button></div>
        </div>
      </div>
    </div>

  </div>
</section>

<div class="divider-strata"><div class="d4"></div><div class="d3"></div><div class="d2"></div><div class="d1"></div></div>

