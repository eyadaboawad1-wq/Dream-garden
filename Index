        </div>
      </div>
    </div>

    <div class="prod-section" id="plants">
      <h3>نباتات وأشجار وبذور</h3>
      <div class="prod-grid">
        <div class="prod-card">
          <div class="prod-thumb"></div>
          <h4>شتلة زيتون</h4>
          <div class="prod-meta">شتلة واحدة</div>
          <div class="prod-row"><span class="price">15.00 ₪</span>
            <button class="add-btn" onclick="addToCart('شتلة زيتون',15.00)">أضف للسلة</button></div>
        </div>
        <div class="prod-card">
          <div class="prod-thumb"></div>
          <h4>نبات زينة داخلي</h4>
          <div class="prod-meta">أصيص واحد</div>
          <div class="prod-row"><span class="price">8.00 ₪</span>
            <button class="add-btn" onclick="addToCart('نبات زينة داخلي',8.00)">أضف للسلة</button></div>
        </div>
        <div class="prod-card">
          <div class="prod-thumb"></div>
          <h4>بذور خضار موسمية متنوعة</h4>
          <div class="prod-meta">عبوة واحدة</div>
