</footer>

<!-- Cart Drawer -->
<div class="overlay" id="overlay" onclick="closeDrawer()"></div>
<div class="drawer" id="drawer">
  <div class="drawer-head">
    <h3>سلة الطلبات</h3>
    <button class="close-btn" onclick="closeDrawer()">✕</button>
  </div>

  <div id="cartView">
    <div class="drawer-body" id="drawerBody">
      <div class="empty-cart" id="emptyMsg">السلة فاضية حالياً — تصفح المنتجات وأضف اللي بدك.</div>
    </div>
    <div class="drawer-footer">
      <div class="total-row"><span>المجموع</span><span id="totalPrice">0.00 ₪</span></div>
      <button class="checkout-btn" id="goCheckoutBtn" onclick="showCheckout()" disabled>إتمام الطلب</button>
    </div>
  </div>

  <div class="checkout-panel" id="checkoutPanel">
    <form id="checkoutForm" onsubmit="submitOrder(event)">
      <div class="field">
        <label>الاسم الكامل *</label>
        <input type="text" required id="custName">
      </div>
      <div class="field">
        <label>رقم الهاتف *</label>
        <input type="tel" required id="custPhone">
      </div>
      <div class="field">
        <label>المدينة والعنوان *</label>
        <input type="text" required id="custAddress">
      </div>
      <div class="field">
        <label>ملاحظات (اختياري)</label>
        <textarea rows="2" id="custNotes"></textarea>
      </div>
      <div class="field">
        <label>طريقة الدفع *</label>
        <div class="pay-options">
          <div class="pay-option selected" data-val="cod" onclick="selectPay(this)">الدفع عند الاستلام</div>
          <div class="pay-option" data-val="online" onclick="selectPay(this)">دفع إلكتروني (PayBox)</div>
        </div>
      </div>
      <button type="submit" class="checkout-btn">تأكيد الطلب</button>
    </form>
  </div>

  <div class="success-msg" id="successMsg">
    <div class="success-icon">✓</div>
    <h3 style="margin-bottom:8px;">تم استلام طلبك!</h3>
    <p style="color:#6b5c47; font-size:14px; margin-bottom:18px;">رقم الطلب: <strong id="orderNum"></strong><br>رح نتواصل معك قريباً لتأكيد التوصيل.</p>
    <button class="checkout-btn" onclick="closeDrawer(); resetAll();">إغلاق</button>
  </div>
</div>

<script>
  let cart = [];
  let payMethod = 'cod';

  function addToCart(name, price){
    const existing = cart.find(i => i.name === name);
    if(existing){ existing.qty += 1; } else { cart.push({name, price, qty:1}); }
    renderCart();
    openDrawer();
  }
  function changeQty(name, delta){
    const item = cart.find(i => i.name === name);
    if(!item) return;
    item.qty += delta;
    if(item.qty <= 0){ cart = cart.filter(i => i.name !== name); }
    renderCart();
  }
  function renderCart(){
    const body = document.getElementById('drawerBody');
    const count = cart.reduce((s,i)=>s+i.qty,0);
    document.getElementById('cartCount').textContent = count;
    const total = cart.reduce((s,i)=>s+i.qty*i.price,0);
    document.getElementById('totalPrice').textContent = total.toFixed(2) + ' ₪';
    document.getElementById('goCheckoutBtn').disabled = cart.length === 0;

    if(cart.length === 0){
      body.innerHTML = '<div class="empty-cart" id="emptyMsg">السلة فاضية حالياً — تصفح المنتجات وأضف اللي بدك.</div>';
      return;
    }
    body.innerHTML = cart.map(i => `
      <div class="cart-item">
        <div>
          <div class="cart-item-name">${i.name}</div>
          <div class="cart-item-meta">${i.price.toFixed(2)} ₪ × ${i.qty}</div>
        </div>
        <div class="qty-controls">
          <button onclick="changeQty('${i.name}', -1)">−</button>
          <span>${i.qty}</span>
          <button onclick="changeQty('${i.name}', 1)">+</button>
        </div>
      </div>
    `).join('');
  }

  function openDrawer(){
    document.getElementById('drawer').classList.add('open');
    document.getElementById('overlay').classList.add('open');
  }
  function closeDrawer(){
    document.getElementById('drawer').classList.remove('open');
    document.getElementById('overlay').classList.remove('open');
  }
  function showCheckout(){
    document.getElementById('cartView').style.display = 'none';
    document.getElementById('checkoutPanel').classList.add('open');
  }
  function selectPay(el){
    document.querySelectorAll('.pay-option').forEach(o => o.classList.remove('selected'));
    el.classList.add('selected');
    payMethod = el.dataset.val;
  }
  function submitOrder(e){
    e.preventDefault();
    document.getElementById('checkoutPanel').classList.remove('open');
    document.getElementById('successMsg').classList.add('open');
    const num = 'DG-' + Math.floor(100000 + Math.random()*900000);
    document.getElementById('orderNum').textContent = num;
  }
  function resetAll(){
    cart = [];
    payMethod = 'cod';
    document.getElementById('checkoutForm').reset();
    document.getElementById('cartView').style.display = 'block';
    document.getElementById('successMsg').classList.remove('open');
    renderCart();
  }
</script>

</body>
</html>
